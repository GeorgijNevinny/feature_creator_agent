# Ключ API: приоритет LLM_API_KEY, иначе OPENAI_API_KEY (OpenAI или совместимый провайдер)
# LLM_API_KEY=
OPENAI_API_KEY=

# Модель чата (для api.openai.com — smol модели; open-weight gpt-oss см. ниже)
OPENAI_MODEL=gpt-4o-mini

# Базовый URL API (по умолчанию https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- openai/gpt-oss-120b НЕ на официальном OpenAI API — нужен совместимый провайдер ---
# Together AI (пример): ключ на https://api.together.ai/
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODEL=openai/gpt-oss-120b
#
# OpenRouter (пример): ключ на https://openrouter.ai/keys
# OpenRouter: базовый URL должен заканчиваться на /api/v1 (иначе 404 и HTML вместо JSON)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-oss-120b
# OPENROUTER_SITE_URL=https://localhost:8501
# OPENROUTER_APP_TITLE=feature_creator_agent

# --- Прокси (ошибка 407 Proxy Authentication Required и др.) ---
# Явный HTTPS-прокси для запросов к LLM (логин и пароль в URL; спецсимволы в пароле — URL-кодировать):
# LLM_PROXY=http://USER:PASSWORD@proxy.example.com:8080
# Если в системе задан HTTPS_PROXY без логина и из-за этого 407 — используйте только явный прокси:
# LLM_IGNORE_SYSTEM_PROXY=1

# Таймаут чтения ответа LLM (секунды)
# LLM_TIMEOUT_SEC=120

# Лимит токенов на ответ (max_tokens в chat completions)
# LLM_MAX_OUTPUT_TOKENS=4096

# Максимальный размер загружаемого CSV (МБ)
CSV_MAX_MB=15

# Максимум строк для расчёта профиля (первые N или случайная выборка — см. CSV_PROFILE_SAMPLE_MODE)
# CSV_PROFILE_MAX_ROWS=50000

# Режим выборки строк для профиля: first | random
# CSV_PROFILE_SAMPLE_MODE=first

# Seed для random (фиксированный для воспроизводимости)
# CSV_PROFILE_SAMPLE_SEED=42
